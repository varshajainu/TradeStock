{
  "name": "tradestock",
  "version": "1.4.0",
  "main": "main.js",
  "build": {
    "appId": "com.devarajareddy.tradestock",
    "productName": "TradeStock",
    "directories": {
      "output": "release/"
    },
    "files": [
      "main.js",
      "dist/tradestock/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "electron:pack": "ng build && electron-builder -w",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:tradestock": "node dist/tradestock/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.2.6",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-server": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@angular/ssr": "^21.1.3",
    "chart.js": "^4.5.1",
    "express": "^5.1.0",
    "ng2-charts": "^10.0.0",
    "ngx-toastr": "^20.0.5",
    "rxjs": "~7.8.0",
    "sqlite3": "^6.0.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "@types/express": "^5.0.1",
    "@types/jasmine": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.19",
    "@types/sqlite3": "^3.1.11",
    "concurrently": "^9.2.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.4"
  }
}
